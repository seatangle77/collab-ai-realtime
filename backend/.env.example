# 密钥统一放根目录 secrets.env，这里只放非敏感配置

# 数据库连接（密码在 secrets.env）
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=collaborative_ai_chatbot
DB_USER=app_user

# 腾讯 ASR（密钥在 secrets.env）
TENCENT_ASR_ENGINE=16k_zh
TENCENT_VAD_SILENCE_TIME_MS=400

# Qwen NLP（密钥在 secrets.env）
NLP_QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
NLP_REASONING_MODEL=qwen-plus
