# 数据库（与 backend 保持一致）
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=collaborative_ai_chatbot
DB_USER=postgres
DB_PASSWORD=

# NLP 微服务（FastAPI backend 地址）
NLP_BASE_URL=http://localhost:8000

# NLP 接口鉴权（X-Admin-Token，与 backend admin token 一致）
ADMIN_TOKEN=

# 定时器间隔（毫秒，一般不需要改）
SHORT_INTERVAL_MS=30000
LONG_INTERVAL_MS=120000
SESSION_POLL_MS=15000
